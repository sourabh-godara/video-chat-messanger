{
    "$schema": "https://json.schemastore.org/tsconfig",
    "display": "Node 16",
    "extends": "./base.json",
    "compilerOptions": {
      "lib": ["ES2021"],
      "module": "CommonJs",
      "moduleResolution":"node",
      "target": "ES2021",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true
    }
  }